# Название приложения/сервиса.
# Используется в логах (как префикс) и в заголовке Swagger-документации.
# Пример: nest-cli-tg, payments-api, crm-backend.
APP_NAME=nest-cli-tg

# Токен Telegram-бота, полученный у @BotFather.
# Нужен для отправки сообщений через Telegraf (API Telegram).
# Пример формата: 123456789:AA... (не публикуйте в репозитории).
TELEGRAM_BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN

# ID пользователя/чата по умолчанию для отправки сообщений.
# Используется CLI-командой send-message, если не передан флаг --user.
# Может быть личный user id или id группы/канала (в зависимости от сценария).
TELEGRAM_DEFAULT_USER=123456789

# Порт HTTP-сервера NestJS.
# На этом порту поднимается API-приложение.
PORT=5943

# Режим запуска приложения.
# Допустимые значения: development | production | test.
# Влияет на выбор env-файла и поведение отдельных функций (например, Swagger).
NODE_ENV=development

# Включение Swagger UI и OpenAPI-документации.
# true  - документация доступна (обычно /api)
# false - документация отключена
ENABLE_SWAGGER=false

# Включение логирования входящих запросов и ответов.
# true  - писать технические HTTP-логи
# false - отключить детальное логирование запросов
ENABLE_REQUEST_LOGGING=false

# Список разрешённых CORS-origin через запятую.
# Пример: https://app.example.com,https://admin.example.com
# Пустое значение означает отсутствие ограничения по origin.
ALLOWED_ORIGINS=
